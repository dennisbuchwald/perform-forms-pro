{
	"name": "flinkform-pro",
	"version": "0.4.0",
	"description": "Pro add-on for Flinkform — integrations, payments & infrastructure. Docks onto the free Flinkform core.",
	"author": "dbw media <hallo@dbw-media.de>",
	"homepage": "https://dbw-media.de/flinkform-pro/",
	"license": "GPL-2.0-or-later",
	"private": true,
	"keywords": [
		"wordpress",
		"gutenberg",
		"forms",
		"webhooks",
		"smtp"
	],
	"engines": {
		"node": ">=20.0.0",
		"npm": ">=10.0.0"
	},
	"scripts": {
		"build": "wp-scripts build && wp-scripts build --webpack-src-dir=blocks/src --output-path=blocks/build",
		"start": "wp-scripts start",
		"lint:js": "wp-scripts lint-js",
		"format": "wp-scripts format",
		"start:blocks": "wp-scripts start --webpack-src-dir=blocks/src --output-path=blocks/build"
	},
	"devDependencies": {
		"@wordpress/scripts": "^30.0.0"
	}
}